# OSU Class Monitor Configuration
# Copy this file to .env and modify the values

# Monitoring Configuration
CHECK_INTERVAL=5  # Check every 5 minutes (in minutes)
LOG_LEVEL=info    # Log level: error, warn, info, verbose, debug

# Notification Settings
ENABLE_DESKTOP_NOTIFICATIONS=true
ENABLE_CONSOLE_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false

# Email Configuration (if email notifications enabled)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=your-email@gmail.com

# Classes to Monitor
# Format: CRN|TERM|SUBJECT|COURSE_NUMBER
# Example: 12345|FALL2024|CS|161
CLASSES_TO_MONITOR=12345|FALL2024|CS|161,67890|FALL2024|MATH|251